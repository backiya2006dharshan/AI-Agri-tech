# Database Configuration
MONGODB_URI=mongodb://localhost:27017/agritech
# or for MongoDB Atlas: MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agritech

# JWT Configuration  
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random

# Email Configuration (choose one method or enable fallbacks)
# Method 1: Gmail SMTP (recommended for development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here
EMAIL_FROM=your.gmail@gmail.com

# Method 2: SendGrid API (recommended for production)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SMTP_USER=noreply@yourdomain.com

# Method 3: Mailgun API (alternative for production)
# MAILGUN_API_KEY=your_mailgun_api_key_here
# MAILGUN_DOMAIN=mg.yourdomain.com

# Optional provider controls
# EMAIL_PREFERRED=sendgrid   # one of: smtp | sendgrid | mailgun
# EMAIL_DISABLE_SMTP=true    # skip SMTP on hosts that block 465/587

# External API Keys
HF_TOKEN=your_huggingface_api_token_here

# Google Gemini AI Configuration (Optional - for enhanced AI task generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Task Generation Configuration
MAX_TASKS_PER_DAY=5
# Maximum number of tasks to generate per crop per day
# Default: 5 tasks
# Recommended range: 3-7 tasks
# Lower values = fewer, more focused tasks
# Higher values = more comprehensive task coverage

# Route Optimization
USE_OPTIMIZED_ROUTES=false
# Set to true to use optimized task routes (if available)

# Server Configuration
PORT=5001
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=info  # error, warn, info, debug
DISABLE_AUTH_LOGS=false
DISABLE_SOCKET_LOGS=false

# OAuth (Google)
# GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Development/Testing
TEST_EMAIL=your.test.email@example.com